@using Appsdemo.TravelCrm.Web.Navigation
@inject IMenuBuilder MenuBuilder
@{
    var tenant = Context.Items["Tenant"] as TenantContext;
    var isAdminHost = Context.Items["IsAdminHost"] as bool? ?? false;
    var isAuthed = Context.User?.Identity?.IsAuthenticated == true;
    var brand = isAdminHost ? "Appsdemo · Super Admin" : (tenant?.CompanyName ?? "Appsdemo Travel CRM");
    var userName = isAuthed ? Context.User!.Identity!.Name : null;
    var planName = tenant?.PlanName;
    var tenantBase = Context.Request.PathBase.Value ?? "";
    var brandHref = isAdminHost ? "/admin" : (string.IsNullOrEmpty(tenantBase) ? "/" : tenantBase + "/");
    var menuTree = isAuthed
        ? MenuBuilder.Build(ViewContext, isAdminHost ? MenuTreeKind.SuperAdmin : MenuTreeKind.Tenant)
        : Array.Empty<MenuGroup>();
    var bodyClass = isAdminHost ? "layout-fluid theme-superadmin" : "layout-fluid";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <title>@(ViewData["Title"] ?? "Appsdemo Travel CRM")</title>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@3.19.0/dist/tabler-icons.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/app.css"/>
    <script>
        (function () {
            var t = localStorage.getItem('tabler-theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body class="@bodyClass">
<div class="page">
    @if (isAuthed)
    {
        @await Html.PartialAsync("_Sidebar", new SidebarVm(menuTree, brand, brandHref, isAdminHost))
    }
    <div class="page-wrapper">
        @if (isAuthed)
        {
            @await Html.PartialAsync("_Topbar", new TopbarVm(userName, planName, isAdminHost, tenantBase))
        }
        <div class="page-body">
            <div class="container-xl">
                @if (TempData["Success"] is string ok)
                {
                    <div class="alert alert-success alert-dismissible" role="alert">
                        <i class="ti ti-check me-2"></i>@ok
                        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
        <footer class="footer footer-transparent d-print-none">
            <div class="container-xl">
                <div class="row text-center align-items-center flex-row-reverse">
                    <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                        <ul class="list-inline list-inline-dots mb-0">
                            <li class="list-inline-item">© @DateTime.UtcNow.Year Appsdemo</li>
                            <li class="list-inline-item">Travel CRM</li>
                        </ul>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/js/tabler.min.js"></script>
<script src="https://unpkg.com/htmx.org@@2.0.3"></script>
<script src="https://cdn.jsdelivr.net/npm/alpinejs@@3.14.1/dist/cdn.min.js" defer></script>
<script src="~/js/app.js"></script>
</body>
</html>

