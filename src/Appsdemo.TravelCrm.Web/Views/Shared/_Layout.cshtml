@{
    var tenant = Context.Items["Tenant"] as TenantContext;
    var isAdminHost = Context.Items["IsAdminHost"] as bool? ?? false;
    var brand = isAdminHost ? "Appsdemo · Super Admin" : (tenant?.CompanyName ?? "Appsdemo Travel CRM");
    var userName = Context.User?.Identity?.IsAuthenticated == true ? Context.User.Identity.Name : null;
    var planName = tenant?.PlanName;
    var tenantBase = Context.Request.PathBase.Value ?? "";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <title>@(ViewData["Title"] ?? "Appsdemo Travel CRM")</title>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@3.19.0/dist/tabler-icons.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/app.css"/>
</head>
<body>
<div class="page">
    @if (Context.User?.Identity?.IsAuthenticated == true)
    {
        <header class="navbar navbar-expand-md navbar-light d-print-none">
            <div class="container-xl">
                <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
                    <a asp-controller="Dashboard" asp-action="Index">
                        <span class="text-primary">@brand</span>
                    </a>
                </h1>
                <div class="navbar-nav flex-row order-md-last">
                    @if (!string.IsNullOrEmpty(planName))
                    {
                        <span class="nav-item d-none d-md-inline-flex align-items-center me-3 badge bg-primary-lt">
                            <i class="ti ti-rocket me-1"></i>@planName
                        </span>
                    }
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown">
                            <span class="avatar avatar-sm">@(userName?.Substring(0,1).ToUpper())</span>
                            <div class="d-none d-xl-block ps-2">
                                <div>@userName</div>
                                <div class="mt-1 small text-secondary">@(isAdminHost ? "Super Admin" : "Tenant User")</div>
                            </div>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end">
                            @if (isAdminHost)
                            {
                                <a href="/admin/logout" class="dropdown-item"><i class="ti ti-logout me-2"></i>Logout</a>
                            }
                            else
                            {
                                <a href="@tenantBase/auth/logout" class="dropdown-item"><i class="ti ti-logout me-2"></i>Logout</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <header class="navbar-expand-md">
            <div class="collapse navbar-collapse" id="navbar-menu">
                <div class="navbar">
                    <div class="container-xl">
                        <ul class="navbar-nav">
                            @if (isAdminHost)
                            {
                                <li class="nav-item"><a class="nav-link" href="/admin"><i class="ti ti-building me-2"></i>Tenants</a></li>
                                <li class="nav-item"><a class="nav-link" href="/admin/tenants/new"><i class="ti ti-plus me-2"></i>New Tenant</a></li>
                                <li class="nav-item"><a class="nav-link" href="/hangfire"><i class="ti ti-clock me-2"></i>Background Jobs</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" href="@tenantBase/"><i class="ti ti-dashboard me-2"></i>Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" href="@tenantBase/users"><i class="ti ti-users me-2"></i>Users</a></li>
                                <li class="nav-item"><a class="nav-link" href="@tenantBase/roles"><i class="ti ti-shield-lock me-2"></i>Roles</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </header>
    }

    <div class="page-wrapper">
        <div class="page-body">
            <div class="container-xl">
                @if (TempData["Success"] is string ok)
                {
                    <div class="alert alert-success alert-dismissible" role="alert">
                        <i class="ti ti-check me-2"></i>@ok
                        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
        <footer class="footer footer-transparent d-print-none">
            <div class="container-xl">
                <div class="row text-center align-items-center flex-row-reverse">
                    <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                        <ul class="list-inline list-inline-dots mb-0">
                            <li class="list-inline-item">© @DateTime.UtcNow.Year Appsdemo</li>
                            <li class="list-inline-item">Travel CRM</li>
                        </ul>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/js/tabler.min.js"></script>
<script src="https://unpkg.com/htmx.org@@2.0.3"></script>
<script src="https://cdn.jsdelivr.net/npm/alpinejs@@3.14.1/dist/cdn.min.js" defer></script>
<script src="~/js/app.js"></script>
</body>
</html>
