@model LeadIndexVm
@{
    ViewData["Title"] = "Leads";
    var pathBase = Context.Request.PathBase.Value ?? "";
    var totalPages = Model.Result.TotalPages == 0 ? 1 : Model.Result.TotalPages;
}

<div class="page-header">
    <div class="row g-2 align-items-center">
        <div class="col"><h2 class="page-title"><i class="ti ti-target-arrow me-2"></i>Leads</h2>
            <div class="text-secondary mt-1">@Model.Result.TotalCount lead(s)</div>
        </div>
        <div class="col-auto">
            <a href="@pathBase/leads/new" class="btn btn-primary">
                <i class="ti ti-plus me-1"></i>New Lead
            </a>
        </div>
    </div>
</div>

<div class="card mb-3">
    <form method="get" class="card-body">
        <div class="row g-2">
            <div class="col-md-4">
                <input name="search" value="@Model.Search" class="form-control"
                       placeholder="Search by lead #, customer name, email or phone"/>
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">All statuses</option>
                    @foreach (var s in LeadStatus.All)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="assignedTo" class="form-select">
                    <option value="">All assignees</option>
                    @foreach (var u in Model.Users)
                    {
                        <option value="@u.Value" selected="@(Model.AssignedTo?.ToString() == u.Value)">@u.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="branchId" class="form-select">
                    <option value="">All branches</option>
                    @foreach (var b in Model.Branches)
                    {
                        <option value="@b.Value" selected="@(Model.BranchId?.ToString() == b.Value)">@b.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-1">
                <button class="btn btn-outline-primary w-100" type="submit"><i class="ti ti-search"></i></button>
            </div>
        </div>
    </form>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
                <tr>
                    <th>Lead #</th><th>Customer</th><th>Contact</th>
                    <th>Travel</th><th>Status</th><th>Assigned</th>
                    <th>Branch</th><th>Created</th><th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Result.Items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-secondary py-5">
                        No leads match your filters. <a href="@pathBase/leads/new">Create the first one →</a>
                    </td></tr>
                }
                @foreach (var l in Model.Result.Items)
                {
                    <tr>
                        <td><a href="@pathBase/leads/@l.Id" class="text-reset"><strong>@l.LeadNo</strong></a></td>
                        <td>@l.CustomerName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(l.Email)) { <div><i class="ti ti-mail me-1 text-secondary"></i>@l.Email</div> }
                            @if (!string.IsNullOrEmpty(l.Phone)) { <div><i class="ti ti-phone me-1 text-secondary"></i>@l.Phone</div> }
                        </td>
                        <td>@(l.TravelDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td><span class="badge bg-@(LeadStatus.BadgeColor(l.Status))-lt">@l.Status</span></td>
                        <td>@(l.AssignedToName ?? "—")</td>
                        <td>@(l.BranchName ?? "—")</td>
                        <td><span class="text-secondary">@l.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span></td>
                        <td class="text-end">
                            <a href="@pathBase/leads/@l.Id" class="btn btn-sm btn-ghost-primary" title="Open"><i class="ti ti-eye"></i></a>
                            <a href="@pathBase/leads/@l.Id/edit" class="btn btn-sm btn-ghost-secondary" title="Edit"><i class="ti ti-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Result.TotalCount > Model.PageSize)
    {
        <div class="card-footer d-flex align-items-center">
            <div class="text-secondary">
                Page @Model.Result.Page of @totalPages
            </div>
            <ul class="pagination m-0 ms-auto">
                @{
                    string PageUrl(int p) =>
                        $"{pathBase}/leads?search={Model.Search}&status={Model.Status}&assignedTo={Model.AssignedTo}&branchId={Model.BranchId}&page={p}&pageSize={Model.PageSize}";
                }
                <li class="page-item @(Model.Result.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Math.Max(1, Model.Result.Page - 1))">prev</a>
                </li>
                <li class="page-item @(Model.Result.Page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@PageUrl(Math.Min(totalPages, Model.Result.Page + 1))">next</a>
                </li>
            </ul>
        </div>
    }
</div>
