@model LeadFormVm
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? $"Edit Lead {Model.LeadNo}" : "New Lead";
    var pathBase = Context.Request.PathBase.Value ?? "";
    var formAction = isEdit ? $"{pathBase}/leads/{Model.Id}/edit" : $"{pathBase}/leads/new";
}

<div class="page-header">
    <h2 class="page-title">
        <i class="ti ti-target-arrow me-2"></i>
        @(isEdit ? $"Edit Lead {Model.LeadNo}" : "New Lead")
    </h2>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        { <li>@err.ErrorMessage</li> }
        </ul>
    </div>
}

<form method="post" action="@formAction">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" name="Id" value="@Model.Id"/> }

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Customer</h3></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label required">Customer name</label>
                            <input name="CustomerName" value="@Model.CustomerName" class="form-control" required maxlength="200"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="Email" value="@Model.Email" class="form-control" maxlength="150"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Phone</label>
                            <input name="Phone" value="@Model.Phone" class="form-control" maxlength="30"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Source</label>
                            <select name="Source" class="form-select">
                                <option value="">— select —</option>
                                @foreach (var s in LeadSource.All)
                                {
                                    <option value="@s" selected="@(Model.Source == s)">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-9 mb-3">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" rows="2" class="form-control" maxlength="2000">@Model.Notes</textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Trip</h3></div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Travel date</label>
                            <input type="date" name="TravelDate" value="@(Model.TravelDate?.ToString("yyyy-MM-dd"))" class="form-control"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Nights</label>
                            <input type="number" min="0" max="365" name="TravelNights" value="@Model.TravelNights" class="form-control"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Adults</label>
                            <input type="number" min="0" name="PaxAdults" value="@Model.PaxAdults" class="form-control"/>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Children</label>
                            <input type="number" min="0" name="PaxChildren" value="@Model.PaxChildren" class="form-control"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Budget</label>
                            <input type="number" step="0.01" min="0" name="Budget" value="@Model.Budget" class="form-control"/>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Currency</label>
                            <input name="CurrencyCode" value="@Model.CurrencyCode" class="form-control" maxlength="3"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header"><h3 class="card-title">Pipeline</h3></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="Status" class="form-select">
                            @foreach (var s in LeadStatus.All)
                            {
                                <option value="@s" selected="@(Model.Status == s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lost reason (if Lost)</label>
                        <input name="LostReason" value="@Model.LostReason" class="form-control" maxlength="200"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assigned to</label>
                        <select name="AssignedTo" class="form-select">
                            <option value="">— unassigned —</option>
                            @foreach (var u in Model.Users)
                            {
                                <option value="@u.Value" selected="@(Model.AssignedTo?.ToString() == u.Value)">@u.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Branch</label>
                        <select name="BranchId" class="form-select">
                            <option value="">— none —</option>
                            @foreach (var b in Model.Branches)
                            {
                                <option value="@b.Value" selected="@(Model.BranchId?.ToString() == b.Value)">@b.Text</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex">
        <a href="@pathBase/leads" class="btn me-auto">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i class="ti ti-device-floppy me-1"></i>@(isEdit ? "Save changes" : "Create lead")
        </button>
    </div>
</form>
